# Локальна MongoDB (npm run dev на хості): обов’язково 127.0.0.1, не "localhost" якщо є проблеми з IPv6
DATABASE_URL="mongodb://127.0.0.1:27017/octave_shop"
# Та сама назва бази, що в URI (для docker compose: mongodb://mongo:27017/$MONGO_DB_NAME)
MONGO_DB_NAME=octave_shop
# Atlas / віддалена БД: mongodb+srv://user:pass@cluster/dbname?retryWrites=true&w=majority
# Демо-товари: npm run db:seed (працює без MongoDB replica set)

# Адмін-панель: пароль для входу
ADMIN_PASSWORD="change-me-in-production"

# Опційно: окремий секрет підпису JWT (рекомендовано в prod; інакше використовується ADMIN_PASSWORD)
# ADMIN_SESSION_SECRET="min-32-chars-random-string-recommended"

# Покупці: JWT-сесія (httpOnly cookie). Якщо не задано — використовується ADMIN_SESSION_SECRET або ADMIN_PASSWORD
# USER_SESSION_SECRET="min-32-chars-random-string-recommended"

# --- Мікросервіси (опційно; якщо задано — checkout іде через order-service) ---
# Спільний секрет між Next (сервер) та сервісами catalog/order (Authorization: Bearer)
# SERVICE_INTERNAL_TOKEN="long-random-string"
# URL order-service (локально після docker compose: http://localhost:4002)
# ORDER_SERVICE_URL="http://localhost:4002"

NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Реальна пошта через Resend (https://resend.com). Без ключа лист не відправляється — замовлення все одно зберігається, помилка логуються.
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Октава <orders@yourdomain.com>"

# Опційно: розподілений rate limit (https://upstash.com). Без змінних використовується in-memory (один інстанс).
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# Додаткові дозволені хости для next/image (через кому), наприклад: cdn.example.com,images.customcdn.io
# NEXT_IMAGE_REMOTE_HOSTS=""
