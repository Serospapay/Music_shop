generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

/// Мікросервіс каталогу: мінімальні поля для перевірки цін і наявності при оформленні
model Product {
  id      String  @id @default(auto()) @map("_id") @db.ObjectId
  name    String
  price   Float
  inStock Boolean @default(true)
}
